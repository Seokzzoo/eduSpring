<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN" "https://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
	<!-- 매퍼 XML 파일에서 사용할 Alias를 선언한다 -->
	<typeAliases>
		<typeAlias alias="board" type="com.multicampus.biz.board.BoardVO"/>
		<typeAlias alias="user" type="com.multicampus.biz.user.UserVO"/>
	</typeAliases>
		
	<!-- SQL 명렁어들이 등록된 매퍼 XML 파일들을 등록한다. -->
  	<mappers>
    	<mapper resource="mappings/board-mapping(mybatis).xml"/>
  	</mappers>
</configuration>